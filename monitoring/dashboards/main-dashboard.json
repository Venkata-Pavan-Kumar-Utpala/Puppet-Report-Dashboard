    { "id": 4, "title": "Run Trends",      "type": "barchart",   "datasource": "/api/dashboard/trends" },
    { "id": 5, "title": "Status Pie",      "type": "piechart",   "datasource": "/api/dashboard/summary" },
    { "id": 6, "title": "Node Status",     "type": "table",      "datasource": "/api/nodes" },
