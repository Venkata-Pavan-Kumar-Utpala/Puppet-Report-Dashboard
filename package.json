{
  "name": "devops-project-puppet-report-dashboard",
  "version": "1.0.0",
  "description": "Puppet Report Dashboard - CSE3253 DevOps Project",
  "main": "src/main/server.js",
  "author": "Venkata Pavan Kumar Utpala <23FE10CSE00388>",
  "license": "MIT",
  "scripts": {
    "start": "node src/main/server.js",
    "dev": "nodemon src/main/server.js",
    "test": "jest --coverage",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:unit": "jest --testPathPattern=tests/unit",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "build": "npm run lint && npm test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "axios": "^1.4.0",
    "winston": "^3.10.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.2"
  },
  "devDependencies": {
    "eslint": "^8.44.0",
    "jest": "^29.6.1",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/main/config/**"
    ]
  }
}
